// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          Int              @id @default(autoincrement())
  name        String
  projectKey  String           @unique
  description String?
  isEnabled   Boolean          @default(true)
  allowAutoRebind Boolean?
  autoRebindCooldownMinutes Int?
  autoRebindMaxCount Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  codes       ActivationCode[]
  bindingHistories ActivationCodeBindingHistory[]
  adminAuditLogs   AdminOperationAuditLog[]

  @@map("projects")
}

model ActivationCode {
  id             Int         @id @default(autoincrement())
  code           String      @unique
  isUsed         Boolean     @default(false)
  usedAt         DateTime?
  usedBy         String?     // 机器ID
  lastBoundAt    DateTime?
  lastRebindAt   DateTime?
  rebindCount    Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  expiresAt      DateTime?
  validDays      Int?        // 时间型激活码有效天数，从激活时开始计算
  cardType       String?     // 套餐类型：如"周卡"、"月卡"、"季卡"、"年卡"等
  projectId      Int
  project        Project     @relation(fields: [projectId], references: [id])
  licenseMode    String      @default("TIME") // TIME | COUNT
  totalCount     Int?        // 次数型激活码总次数
  remainingCount Int?        // 次数型激活码剩余次数
  consumedCount  Int         @default(0)
  allowAutoRebind Boolean?
  autoRebindCooldownMinutes Int?
  autoRebindMaxCount Int?
  autoRebindCount Int       @default(0)
  consumptions   LicenseConsumption[]
  bindingHistories ActivationCodeBindingHistory[]
  adminAuditLogs   AdminOperationAuditLog[]

  @@unique([projectId, usedBy], map: "activation_codes_projectId_usedBy_key")
  @@index([projectId], map: "activation_codes_projectId_idx")
  @@index([projectId, usedBy, isUsed, usedAt], map: "activation_codes_projectId_usedBy_isUsed_usedAt_idx")
  @@map("activation_codes")
}

model ActivationCodeBindingHistory {
  id             Int            @id @default(autoincrement())
  activationCodeId Int
  activationCode ActivationCode @relation(fields: [activationCodeId], references: [id])
  projectId      Int
  project        Project        @relation(fields: [projectId], references: [id])
  eventType      String
  operatorType   String
  operatorUsername String?
  fromMachineId  String?
  toMachineId    String?
  reason         String?
  createdAt      DateTime       @default(now())

  @@index([activationCodeId, createdAt], map: "activation_code_binding_histories_activationCodeId_createdAt_idx")
  @@index([projectId, createdAt], map: "activation_code_binding_histories_projectId_createdAt_idx")
  @@map("activation_code_binding_histories")
}

model AdminOperationAuditLog {
  id             Int             @id @default(autoincrement())
  adminUsername  String
  operationType  String
  activationCodeId Int?
  activationCode ActivationCode? @relation(fields: [activationCodeId], references: [id])
  projectId      Int?
  project        Project?        @relation(fields: [projectId], references: [id])
  targetLabel    String?
  reason         String?
  detailJson     String?
  createdAt      DateTime        @default(now())

  @@index([activationCodeId, createdAt], map: "admin_operation_audit_logs_activationCodeId_createdAt_idx")
  @@index([projectId, createdAt], map: "admin_operation_audit_logs_projectId_createdAt_idx")
  @@index([adminUsername, createdAt], map: "admin_operation_audit_logs_adminUsername_createdAt_idx")
  @@map("admin_operation_audit_logs")
}

model LicenseConsumption {
  id                  Int            @id @default(autoincrement())
  requestId           String         @unique
  activationCodeId    Int
  activationCode      ActivationCode @relation(fields: [activationCodeId], references: [id])
  machineId           String
  remainingCountAfter Int
  createdAt           DateTime       @default(now())

  @@index([activationCodeId], map: "license_consumptions_activationCodeId_idx")
  @@index([activationCodeId, createdAt], map: "license_consumptions_activationCodeId_createdAt_idx")
  @@index([createdAt, id], map: "license_consumptions_createdAt_id_idx")
  @@map("license_consumptions")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // bcrypt哈希
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model AdminLoginRateLimitState {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  failuresJson String  @default("[]")
  lockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admin_login_rate_limits")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}
